---
import BaseLayout from '../layouts/BaseLayout.astro';
import { url } from '../utils/url';
---

<BaseLayout
  title="Pagina niet gevonden"
  description="De pagina die je zoekt bestaat niet of is verplaatst."
>
  <section class="not-found section">
    <div class="container not-found__inner">
      <p class="not-found__code">404</p>
      <h1 class="not-found__heading">Pagina niet gevonden</h1>
      <p class="not-found__body">
        De pagina die je zoekt bestaat niet of is verplaatst. Ga terug naar de
        homepage of bekijk onze agenda en leergangen.
      </p>
      <div class="not-found__links">
        <a href={url('/')} class="btn-primary">Naar de homepage</a>
        <a href={url('/#agenda')} class="not-found__secondary">Bekijk de agenda</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    min-height: calc(100vh - var(--nav-height) - 8rem);
    display: flex;
    align-items: center;
  }

  .not-found__inner {
    max-width: 48ch;
  }

  .not-found__code {
    font-size: clamp(4rem, 12vw, 8rem);
    font-weight: 700;
    color: var(--color-bg-tinted-dark);
    line-height: 1;
    margin-bottom: var(--space-xs);
  }

  .not-found__heading {
    color: var(--color-primary);
    margin-bottom: var(--space-sm);
  }

  .not-found__body {
    color: var(--color-text-muted);
    line-height: 1.8;
    margin-bottom: var(--space-md);
  }

  .not-found__links {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-block;
  }

  .not-found__secondary {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-primary);
    text-decoration: underline;
    text-decoration-color: var(--color-text-muted);
    text-underline-offset: 3px;
  }

  .not-found__secondary:hover {
    text-decoration-color: var(--color-primary);
  }

  .not-found__secondary:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
    border-radius: var(--radius-sm);
  }
</style>
