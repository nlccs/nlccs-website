---
import { getEntry } from 'astro:content';
import EventLayout from '../../layouts/EventLayout.astro';

const entry = await getEntry('masterclasses', 'onderwijsmatig-toetsen');
const { title, date, time_start, time_end, location, cost, level, studielast, deelnemers, accreditation, sfeerfoto, intro, body } = entry.data;
---

<EventLayout {title} {date} timeStart={time_start} timeEnd={time_end} {location} {cost} {level} {studielast} {deelnemers} {accreditation} {sfeerfoto} {intro}>
  {body?.split("\n\n").map(para => <p>{para}</p>)}
</EventLayout>
