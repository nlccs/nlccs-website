---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import DetailLayout from '../../layouts/DetailLayout.astro';
import Paragraphs from '../../components/Paragraphs.astro';
import { url } from '../../utils/url';

export async function getStaticPaths() {
  const entries = await getCollection('masterclasses');
  return entries.map(entry => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'masterclasses'>;
}

const { entry } = Astro.props;
const { title, type, date, time_start, time_end, location, cost, level, studielast, deelnemers, accreditation, aanmeld_url, sfeerfoto, intro, body } = entry.data;
---

<DetailLayout
  {title}
  eyebrow={type}
  description={`${type} ${title} op ${location}.`}
  backHref="/#agenda"
  backLabel="Terug naar de agenda"
  contentHeading="Over deze masterclass"
  {date}
  timeStart={time_start}
  timeEnd={time_end}
  {location}
  {cost}
  {level}
  {studielast}
  {deelnemers}
  {accreditation}
  aanmeldUrl={aanmeld_url}
  {sfeerfoto}
  {intro}
>
  {body && <Paragraphs text={body} />}
</DetailLayout>
