---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import LeergangenLayout from '../../layouts/LeergangenLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('leergangen');
  return entries.map(entry => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'leergangen'>;
}

const { entry } = Astro.props;
const { title, startdatum, location, cost, level, studielast, deelnemers, aanmeld_url, intro, sfeerfoto, body } = entry.data;
---

<LeergangenLayout {title} {startdatum} {location} {cost} {level} {studielast} {deelnemers} aanmeldUrl={aanmeld_url} {intro} {sfeerfoto}>
  {body.split('\n\n').map(para => <p>{para}</p>)}
</LeergangenLayout>
