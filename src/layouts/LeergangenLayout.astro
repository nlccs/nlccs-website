---
import BaseLayout from './BaseLayout.astro';
import { url } from '../utils/url';
import { format } from 'date-fns';
import { nl } from 'date-fns/locale';

interface Props {
  title: string;
  startdatum?: Date;
  location?: string;
  cost?: string;
  level?: string;
  studielast?: string;
  deelnemers?: string;
  aanmeldUrl?: string;
  intro?: string;
  sfeerfoto?: string;
}

const {
  title,
  startdatum,
  location,
  cost = 'Nader te bepalen',
  level = 'Schoolleiders',
  studielast,
  deelnemers,
  aanmeldUrl,
  intro,
  sfeerfoto,
} = Astro.props;

const datumLabel = startdatum ? format(startdatum, 'd MMMM yyyy', { locale: nl }) : null;
---

<BaseLayout title={`${title} — NLCCS`} description={`Leergang ${title}, start ${datumLabel}.`}>
  <article class="leergang-page">
    <header class="leergang-page__header section--primary">
      <div class="container">
        <a href={url('/#leergangen')} class="leergang-page__back">← Terug naar leergangen</a>
        <p class="leergang-page__eyebrow">Leergang</p>
        <h1 class="leergang-page__title">{title}</h1>
      </div>
    </header>

    <div class="leergang-page__body container">
      <aside class="leergang-page__meta">
        <dl class="meta-list">
          {startdatum && datumLabel && (
            <div class="meta-list__item">
              <dt>Startdatum</dt>
              <dd><time datetime={format(startdatum, 'yyyy-MM-dd')}>{datumLabel}</time></dd>
            </div>
          )}
          {location && (
            <div class="meta-list__item">
              <dt>Locatie</dt>
              <dd>{location}</dd>
            </div>
          )}
          <div class="meta-list__item">
            <dt>Kosten</dt>
            <dd>{cost}</dd>
          </div>
          <div class="meta-list__item">
            <dt>Niveau</dt>
            <dd>{level}</dd>
          </div>
          {studielast && (
            <div class="meta-list__item">
              <dt>Studielast</dt>
              <dd>{studielast}</dd>
            </div>
          )}
          {deelnemers && (
            <div class="meta-list__item">
              <dt>Deelnemers</dt>
              <dd>{deelnemers}</dd>
            </div>
          )}
        </dl>
        {aanmeldUrl && (
          <a href={aanmeldUrl} class="btn-primary" target="_blank" rel="noopener noreferrer">Aanmelden</a>
        )}
      </aside>

      <div class="leergang-page__content">
        <h2>Over deze leergang</h2>
        {intro && <p class="leergang-page__intro">{intro}</p>}
        {sfeerfoto && (
          <figure class="leergang-page__sfeer">
            <img
              src={url(sfeerfoto)}
              alt={`Sfeerimpressie ${title}`}
              loading="lazy"
              class="leergang-page__sfeer-img"
            />
          </figure>
        )}
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .leergang-page__header {
    padding-block: var(--space-lg);
  }

  .leergang-page__back {
    display: inline-block;
    font-size: 0.9rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    margin-bottom: var(--space-sm);
    transition: color 0.2s;
  }

  .leergang-page__back:hover { color: var(--color-white); }

  .leergang-page__eyebrow {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 0.35rem;
  }

  .leergang-page__title {
    color: var(--color-white);
    font-size: clamp(1.5rem, 4vw, 2.5rem);
  }

  .leergang-page__body {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: var(--space-lg);
    padding-block: var(--space-lg);
    align-items: start;
  }

  @media (max-width: 768px) {
    .leergang-page__body {
      grid-template-columns: 1fr;
    }
  }

  .leergang-page__meta {
    background: var(--color-bg-warm);
    border-radius: 6px;
    padding: var(--space-md);
    position: sticky;
    top: calc(var(--nav-height) + var(--space-sm));
  }

  .meta-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .meta-list__item dt {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .meta-list__item dd {
    font-weight: 600;
    color: var(--color-text);
    margin-top: 0.1rem;
  }

  .btn-primary {
    display: block;
    text-align: center;
    background: var(--color-primary);
    color: var(--color-white);
    font-weight: 700;
    font-size: 0.95rem;
    padding: 0.75rem 1.5rem;
    border-radius: 4px;
    text-decoration: none;
    transition: background 0.2s;
  }

  .btn-primary:hover { background: var(--color-primary-dark); }

  .leergang-page__content {
    max-width: 72ch;
    line-height: 1.8;
  }

  .leergang-page__intro {
    font-size: 1.2rem;
    line-height: 1.8;
    color: var(--color-text-muted);
    font-weight: 300;
    margin-top: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .leergang-page__sfeer {
    margin-top: var(--space-md);
    margin-bottom: var(--space-md);
    border-radius: 8px;
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }

  .leergang-page__sfeer-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .leergang-page__content :global(h2) {
    color: var(--color-primary);
    margin-top: var(--space-md);
    margin-bottom: var(--space-sm);
  }

  .leergang-page__content :global(p) {
    margin-bottom: var(--space-sm);
    color: var(--color-text);
  }
</style>
