---
import BaseLayout from './BaseLayout.astro';
import { url } from '../utils/url';
import { formatTimeRange } from '../utils/time';
import { format } from 'date-fns';
import { nl } from 'date-fns/locale';

interface Props {
  // Page identity
  title: string;
  eyebrow: string;
  description: string;
  // Navigation
  backHref: string;
  backLabel: string;
  contentHeading: string;
  // Date — pass `date` for events, `startdatum` for leergangen
  date?: Date;
  timeStart?: string;
  timeEnd?: string;
  startdatum?: Date;
  // Meta sidebar
  location?: string;
  cost?: string;
  level?: string;
  studielast?: string;
  deelnemers?: string;
  accreditation?: string;
  aanmeldUrl?: string;
  // Content
  sfeerfoto?: string;
  intro?: string;
}

const {
  title,
  eyebrow,
  description,
  backHref,
  backLabel,
  contentHeading,
  date,
  timeStart,
  timeEnd,
  startdatum,
  location,
  cost = 'Nader te bepalen',
  level,
  studielast,
  deelnemers,
  accreditation,
  aanmeldUrl,
  sfeerfoto,
  intro,
} = Astro.props;

const dateLabel    = date       ? format(date,       'd MMMM yyyy', { locale: nl }) : null;
const startLabel   = startdatum ? format(startdatum, 'd MMMM yyyy', { locale: nl }) : null;
const timeLabel    = formatTimeRange(timeStart, timeEnd);
---

<BaseLayout title={`${title} — NLCCS`} {description}>
  <article class="detail-page">
    <header class="detail-page__header section--primary">
      <div class="container">
        <a href={url(backHref)} class="detail-page__back">← {backLabel}</a>
        <p class="detail-page__eyebrow">{eyebrow}</p>
        <h1 class="detail-page__title">{title}</h1>
      </div>
    </header>

    <div class="detail-page__body container">
      <aside class="detail-page__meta">
        <dl class="meta-list">
          {date && dateLabel && (
            <div class="meta-list__item">
              <dt>Datum</dt>
              <dd>
                <time datetime={format(date, 'yyyy-MM-dd')}>{dateLabel}</time>
                {timeLabel && <span class="detail-meta__time">{timeLabel}</span>}
              </dd>
            </div>
          )}
          {startdatum && startLabel && (
            <div class="meta-list__item">
              <dt>Startdatum</dt>
              <dd><time datetime={format(startdatum, 'yyyy-MM-dd')}>{startLabel}</time></dd>
            </div>
          )}
          {location && (
            <div class="meta-list__item">
              <dt>Locatie</dt>
              <dd>{location}</dd>
            </div>
          )}
          <div class="meta-list__item">
            <dt>Kosten</dt>
            <dd>{cost}</dd>
          </div>
          {level && (
            <div class="meta-list__item">
              <dt>Niveau</dt>
              <dd>{level}</dd>
            </div>
          )}
          {studielast && (
            <div class="meta-list__item">
              <dt>Studielast</dt>
              <dd>{studielast}</dd>
            </div>
          )}
          {deelnemers && (
            <div class="meta-list__item">
              <dt>Deelnemers</dt>
              <dd>{deelnemers}</dd>
            </div>
          )}
          {accreditation && (
            <div class="meta-list__item">
              <dt>Accreditatie</dt>
              <dd>{accreditation}</dd>
            </div>
          )}
        </dl>
        {aanmeldUrl && (
          <a href={aanmeldUrl} class="btn-primary" target="_blank" rel="noopener noreferrer">Aanmelden</a>
        )}
      </aside>

      <div class="detail-page__content">
        <h2>{contentHeading}</h2>
        {intro && <p class="detail-page__intro">{intro}</p>}
        {sfeerfoto && (
          <figure class="detail-page__sfeer">
            <img
              src={url(sfeerfoto)}
              alt={`Sfeerimpressie ${title}`}
              loading="lazy"
              class="detail-page__sfeer-img"
            />
          </figure>
        )}
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .detail-page__header {
    padding-block: var(--space-lg);
  }

  .detail-page__back {
    display: inline-block;
    font-size: 0.9rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    margin-bottom: var(--space-sm);
    transition: color 0.2s;
  }

  .detail-page__back:hover { color: var(--color-white); }

  .detail-page__eyebrow {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: var(--space-2xs);
  }

  .detail-page__title {
    color: var(--color-white);
    font-size: clamp(1.5rem, 4vw, 2.5rem);
  }

  .detail-page__body {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: var(--space-lg);
    padding-block: var(--space-lg);
    align-items: start;
  }

  @media (max-width: 768px) {
    .detail-page__body {
      grid-template-columns: 1fr;
    }

    .detail-page__content {
      order: 1;
    }

    .detail-page__meta {
      order: 2;
      position: static;
    }
  }

  .detail-page__meta {
    background: var(--color-bg-warm);
    border-radius: var(--radius-md);
    padding: var(--space-md);
    position: sticky;
    top: calc(var(--nav-height) + var(--space-sm));
  }

  .detail-meta__time {
    display: block;
    font-weight: 400;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-top: var(--space-2xs);
  }

  .detail-page__content {
    max-width: 72ch;
    line-height: 1.8;
  }

  .detail-page__intro {
    font-size: 1.2rem;
    line-height: 1.8;
    color: var(--color-text-muted);
    font-weight: 300;
    margin-top: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .detail-page__content :global(h2) {
    color: var(--color-primary);
    margin-top: var(--space-md);
    margin-bottom: var(--space-sm);
  }

  .detail-page__content :global(p) {
    margin-bottom: var(--space-sm);
    color: var(--color-text);
  }

  .detail-page__sfeer {
    margin-top: var(--space-md);
    margin-bottom: var(--space-md);
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }

  .detail-page__sfeer-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }
</style>
