---
import { url } from '../utils/url';
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__left">
      <p class="footer__name">Nederlands Centrum voor Curriculumstudies</p>
      <a href="mailto:info@nlccs.nl" class="footer__mail">
        <svg class="footer__mail-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="M3 4a1 1 0 0 0-1 1v.586l8 5.333 8-5.333V5a1 1 0 0 0-1-1H3Z"/>
          <path d="M18 7.414l-7.447 4.964a1 1 0 0 1-1.106 0L2 7.414V15a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1V7.414Z"/>
        </svg>
        info@nlccs.nl
      </a>
    </div>
    <nav class="footer__legal" aria-label="Juridische informatie">
      <a href={url('/algemene-voorwaarden/')} class="footer__legal-link">Algemene voorwaarden</a>
      <a href={url('/examenreglement/')} class="footer__legal-link">Examenreglement</a>
      <a href={url('/privacy/')} class="footer__legal-link">Privacy &amp; AVG</a>
    </nav>
    <p class="footer__copy">&copy; {new Date().getFullYear()} NLCCS</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-primary);
    color: var(--color-white);
    padding-block: var(--space-md);
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1fr auto auto;
    align-items: center;
    gap: var(--space-sm) var(--space-md);
  }

  .footer__name {
    font-weight: 600;
    font-size: 0.9rem;
  }

  .footer__left {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }

  .footer__mail {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-white);
    text-decoration: none;
    opacity: 0.75;
    transition: opacity 0.2s;
  }

  .footer__mail:hover {
    opacity: 1;
  }

  .footer__mail-icon {
    width: 0.95rem;
    height: 0.95rem;
    flex-shrink: 0;
  }

  .footer__mail:focus-visible {
    outline: 2px solid var(--color-highlight);
    outline-offset: 3px;
    border-radius: var(--radius-sm);
  }

  .footer__legal {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs) var(--space-sm);
    align-items: center;
  }

  .footer__legal-link {
    font-size: 0.8rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer__legal-link:hover {
    color: var(--color-white);
  }

  .footer__legal-link:focus-visible {
    outline: 2px solid var(--color-highlight);
    outline-offset: 3px;
    border-radius: var(--radius-sm);
  }

  .footer__copy {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.65);
  }

  @media (max-width: 700px) {
    .footer__inner {
      grid-template-columns: 1fr;
      gap: var(--space-sm);
    }

    .footer__legal {
      gap: var(--space-xs) var(--space-sm);
      border-top: 1px solid rgba(255, 255, 255, 0.15);
      padding-top: var(--space-sm);
    }

    .footer__copy {
      border-top: 1px solid rgba(255, 255, 255, 0.15);
      padding-top: var(--space-sm);
    }
  }
</style>
