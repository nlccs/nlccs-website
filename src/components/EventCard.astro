---
import { url } from '../utils/url';
import { formatTimeRange } from '../utils/time';
import { format } from 'date-fns';
import { nl } from 'date-fns/locale';

interface Props {
  date: Date;
  timeStart?: string;  // e.g. "09:00"
  timeEnd?: string;    // e.g. "17:00"
  title: string;
  location: string;
  slug: string;
}

const { date, timeStart, timeEnd, title, location, slug } = Astro.props;

const dateIso = format(date, 'yyyy-MM-dd');
const dateLabel = format(date, 'd MMMM yyyy', { locale: nl });
const timeLabel = formatTimeRange(timeStart, timeEnd);
---

<article class="event-card">
  <time class="event-card__date" datetime={dateIso}>
    {dateLabel}{timeLabel && <span class="event-card__time"> · {timeLabel}</span>}
  </time>
  <h3 class="event-card__title">{title}</h3>
  <p class="event-card__location">
    <span class="event-card__pin" aria-hidden="true">📍</span>
    {location}
  </p>
  <a href={url(`/masterclass/${slug}/`)} class="event-card__link" aria-label={`Meer info over ${title}`}>
    Meer informatie →
  </a>
</article>

<style>
  .event-card {
    background: var(--color-white);
    border: 1px solid var(--color-bg-warm-dark);
    border-radius: 6px;
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    transition: box-shadow 0.2s;
  }

  .event-card:hover {
    box-shadow: 0 4px 20px rgba(19, 29, 119, 0.12);
  }

  .event-card__date {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .event-card__time {
    font-weight: 400;
    letter-spacing: 0;
  }

  .event-card__title {
    font-size: 1.1rem;
    color: var(--color-primary);
    line-height: 1.3;
    margin-top: 0.25rem;
  }

  .event-card__location {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .event-card__pin {
    font-size: 0.85rem;
  }

  .event-card__link {
    display: inline-block;
    margin-top: auto;
    padding-top: var(--space-sm);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-primary);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s;
    align-self: flex-start;
  }

  .event-card__link:hover {
    border-bottom-color: var(--color-primary);
  }
</style>
