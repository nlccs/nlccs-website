---
import { getCollection } from 'astro:content';
import { url } from '../utils/url';
import { compareAsc, format } from 'date-fns';
import { nl } from 'date-fns/locale';
import Paragraphs from './Paragraphs.astro';

const entries = await getCollection('leergangen');
const leergangen = entries
  .map(e => e.data)
  .sort((a, b) => {
    if (!a.startdatum && !b.startdatum) return 0;
    if (!a.startdatum) return 1;
    if (!b.startdatum) return -1;
    return compareAsc(a.startdatum, b.startdatum);
  });
---

<section id="leergangen" class="section section--tinted">
  <div class="container">
    <h2 class="leergangen__heading">Leergangen</h2>
    <div class="leergangen__grid">
      {leergangen.map(({ title, slug, startdatum, location, intro, body }) => (
        <div class="leergang">
          <div class="leergang__meta">
            {startdatum && (
              <time class="leergang__date" datetime={format(startdatum, 'yyyy-MM-dd')}>
                Start: {format(startdatum, 'd MMMM yyyy', { locale: nl })}
              </time>
            )}
            {location && <span class="leergang__location"><span aria-hidden="true">📍</span> {location}</span>}
          </div>
          <h3 class="leergang__title">{title}</h3>
          <Paragraphs text={intro ?? body} class="leergang__body" />
          <a href={url(`/leergang/${slug}/`)} class="leergang__link" aria-label={`Meer informatie over ${title}`}>
            Meer informatie <span aria-hidden="true">→</span>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .leergangen__heading {
    color: var(--color-primary);
    margin-bottom: var(--space-md);
  }

  .leergangen__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
  }

  @media (max-width: 640px) {
    .leergangen__grid {
      grid-template-columns: 1fr;
    }
  }

  .leergang {
    background: var(--color-white);
    border-left: 4px solid var(--color-primary);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    padding: var(--space-md);
  }

  .leergang__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-xs);
  }

  .leergang__date {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .leergang__location {
    font-size: 0.82rem;
    color: var(--color-text-muted);
  }

  .leergang__title {
    color: var(--color-primary);
    margin-bottom: var(--space-sm);
    font-size: 1.1rem;
  }

  .leergang__body {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.75;
    margin-bottom: var(--space-sm);
  }

  .leergang__body:last-of-type {
    margin-bottom: 0;
  }

  .leergang__link {
    display: inline-block;
    margin-top: var(--space-sm);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-primary);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s;
  }

  .leergang__link:hover {
    border-bottom-color: var(--color-primary);
  }

  .leergang__link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
    border-radius: var(--radius-sm);
  }
</style>
