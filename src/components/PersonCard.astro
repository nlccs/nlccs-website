---
import { url } from '../utils/url';

interface Props {
  name: string;
  photo: string;
  bio: string;
  email?: string;
}

const { name, photo, bio, email } = Astro.props;
---

<article class="person-card">
  <div class="person-card__photo-wrap">
    <img
      src={url(photo)}
      alt={name}
      width="400"
      height="400"
      loading="lazy"
      class="person-card__photo"
    />
  </div>
  <div class="person-card__content">
    <h3 class="person-card__name">{name}</h3>
    <p class="person-card__bio">{bio}</p>
    {email && (
      <a href={`mailto:${email}`} class="person-card__email">
        <svg class="person-card__email-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="M3 4a1 1 0 0 0-1 1v.586l8 5.333 8-5.333V5a1 1 0 0 0-1-1H3Z"/>
          <path d="M18 7.414l-7.447 4.964a1 1 0 0 1-1.106 0L2 7.414V15a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1V7.414Z"/>
        </svg>
        {email}
      </a>
    )}
  </div>
</article>

<style>
  .person-card {
    background: var(--color-white);
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--color-bg-tinted-dark);
    display: flex;
    flex-direction: column;
  }

  .person-card__photo-wrap {
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--color-primary);
  }

  .person-card__photo {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .person-card__content {
    padding: var(--space-md);
    flex: 1;
  }

  .person-card__name {
    color: var(--color-primary);
    font-size: 1.1rem;
    margin-bottom: var(--space-xs);
  }

  .person-card__bio {
    font-size: 0.9rem;
    line-height: 1.75;
    color: var(--color-text-muted);
  }

  .person-card__email {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);
    margin-top: var(--space-sm);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
    opacity: 0.75;
    transition: opacity 0.2s;
  }

  .person-card__email:hover {
    opacity: 1;
  }

  .person-card__email:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
    border-radius: var(--radius-sm);
  }

  .person-card__email-icon {
    width: 0.95rem;
    height: 0.95rem;
    flex-shrink: 0;
  }
</style>
