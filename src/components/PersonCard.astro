---
import { url } from '../utils/url';

interface Props {
  name: string;
  photo?: string;
  bio: string;
  email?: string;
}

const { name, photo, bio, email } = Astro.props;

const initials = name
  .split(' ')
  .filter((_, i, arr) => i === 0 || i === arr.length - 1)
  .map(w => w[0].toUpperCase())
  .join('');

const bgColors = ['#131d77', '#1e2d99', '#0d1560'];
const hash = name.split('').reduce((acc, c) => acc + c.charCodeAt(0), 0);
const bg = bgColors[hash % bgColors.length];
---

<article class="person-card">
  <div class="person-card__photo-wrap">
    {photo ? (
      <img
        src={url(photo)}
        alt={name}
        width="400"
        height="400"
        loading="lazy"
        class="person-card__photo"
      />
    ) : (
      <svg class="person-card__placeholder" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <rect width="200" height="200" fill={bg} />
        <text
          x="100"
          y="100"
          font-family="Open Sans, sans-serif"
          font-size="72"
          font-weight="700"
          fill="rgba(255,255,255,0.85)"
          text-anchor="middle"
          dominant-baseline="central"
        >{initials}</text>
      </svg>
    )}
  </div>
  <div class="person-card__content">
    <h3 class="person-card__name">{name}</h3>
    <p class="person-card__bio">{bio}</p>
    {email && (
      <a href={`mailto:${email}`} class="person-card__email">
        <svg class="person-card__email-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="M3 4a1 1 0 0 0-1 1v.586l8 5.333 8-5.333V5a1 1 0 0 0-1-1H3Z"/>
          <path d="M18 7.414l-7.447 4.964a1 1 0 0 1-1.106 0L2 7.414V15a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1V7.414Z"/>
        </svg>
        {email}
      </a>
    )}
  </div>
</article>

<style>
  .person-card {
    background: var(--color-white);
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--color-bg-tinted-dark);
    display: flex;
    flex-direction: column;
  }

  .person-card__photo-wrap {
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--color-primary);
  }

  .person-card__photo,
  .person-card__placeholder {
    width: 100%;
    height: 100%;
    display: block;
  }

  .person-card__photo {
    object-fit: cover;
  }

  .person-card__content {
    padding: var(--space-md);
    flex: 1;
  }

  .person-card__name {
    color: var(--color-primary);
    font-size: 1.1rem;
    margin-bottom: var(--space-xs);
  }

  .person-card__bio {
    font-size: 0.9rem;
    line-height: 1.75;
    color: var(--color-text-muted);
  }

  .person-card__email {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);
    margin-top: var(--space-sm);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: none;
    opacity: 0.75;
    transition: opacity 0.2s;
  }

  .person-card__email:hover {
    opacity: 1;
  }

  .person-card__email-icon {
    width: 0.95rem;
    height: 0.95rem;
    flex-shrink: 0;
  }
</style>
