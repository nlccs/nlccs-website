---
import { url } from '../utils/url';

interface Props {
  name: string;
  photo?: string;  // path relative to /public/team/ — optional, falls back to initials
  bio: string;
}

const { name, photo, bio } = Astro.props;

const initials = name
  .split(' ')
  .filter((_, i, arr) => i === 0 || i === arr.length - 1)
  .map(w => w[0].toUpperCase())
  .join('');

const bgColors = ['#131d77', '#1e2d99', '#0d1560'];
const hash = name.split('').reduce((acc, c) => acc + c.charCodeAt(0), 0);
const bg = bgColors[hash % bgColors.length];
---

<article class="person-card">
  <div class="person-card__photo-wrap">
    {photo ? (
      <img
        src={url(photo)}
        alt={name}
        width="400"
        height="400"
        loading="lazy"
        class="person-card__photo"
      />
    ) : (
      <svg class="person-card__placeholder" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <rect width="200" height="200" fill={bg} />
        <text
          x="100"
          y="100"
          font-family="Open Sans, sans-serif"
          font-size="72"
          font-weight="700"
          fill="rgba(255,255,255,0.85)"
          text-anchor="middle"
          dominant-baseline="central"
        >{initials}</text>
      </svg>
    )}
  </div>
  <div class="person-card__content">
    <h3 class="person-card__name">{name}</h3>
    <p class="person-card__bio">{bio}</p>
  </div>
</article>

<style>
  .person-card {
    background: var(--color-white);
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid var(--color-bg-warm-dark);
    display: flex;
    flex-direction: column;
  }

  .person-card__photo-wrap {
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--color-primary);
  }

  .person-card__photo,
  .person-card__placeholder {
    width: 100%;
    height: 100%;
    display: block;
  }

  .person-card__photo {
    object-fit: cover;
  }

  .person-card__content {
    padding: var(--space-md);
    flex: 1;
  }

  .person-card__name {
    color: var(--color-primary);
    font-size: 1.1rem;
    margin-bottom: var(--space-xs);
  }

  .person-card__bio {
    font-size: 0.9rem;
    line-height: 1.75;
    color: var(--color-text-muted);
  }
</style>
