---
import { getCollection } from 'astro:content';
import PersonCard from './PersonCard.astro';

interface Props {
  title: string;
  bodyHtml: string;
}

const { title, bodyHtml } = Astro.props;

const entries = await getCollection('team');
const team = entries
  .map(e => e.data)
  .sort((a, b) => a.order - b.order);
---

<section id="over-ons" class="section">
  <div class="container">
    <h2 class="over-ons__heading">{title}</h2>
    <div class="over-ons__body" set:html={bodyHtml} />
    <div class="over-ons__grid">
      {team.map((person) => (
        <PersonCard name={person.name} photo={person.photo} bio={person.bio} email={person.email} />
      ))}
    </div>
  </div>
</section>

<style>
  .over-ons__heading {
    color: var(--color-primary);
    margin-bottom: var(--space-md);
  }

  .over-ons__body {
    max-width: 72ch;
    margin-bottom: var(--space-lg);
  }

  .over-ons__body :global(p) {
    line-height: 1.8;
    margin-bottom: var(--space-sm);
  }

  .over-ons__body :global(p:last-child) {
    margin-bottom: 0;
    font-style: italic;
    color: var(--color-text-muted);
  }

  .over-ons__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--space-md);
  }
</style>
