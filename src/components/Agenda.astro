---
import { getCollection } from 'astro:content';
import EventCard from './EventCard.astro';

const entries = await getCollection('masterclasses');
const events = entries
  .map(e => e.data)
  .sort((a, b) => a.slug.localeCompare(b.slug)); // stable order; sort by date if you prefer
---

<section id="agenda" class="section">
  <div class="container">
    <h2 class="agenda__heading">Agenda</h2>
    <div class="agenda__grid">
      {events.map((event) => (
        <EventCard
          date={event.date}
          title={`Masterclass '${event.title}'`}
          location={event.location}
          slug={event.slug}
        />
      ))}
    </div>
  </div>
</section>

<style>
  .agenda__heading {
    color: var(--color-primary);
    margin-bottom: var(--space-md);
  }

  .agenda__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-md);
  }
</style>
