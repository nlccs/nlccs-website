---
import { url } from '../utils/url';
import { getCollection } from 'astro:content';
import { compareAsc } from 'date-fns';

const leergangEntries = await getCollection('leergangen');
const leergangen = leergangEntries
  .map(e => e.data)
  .sort((a, b) => {
    if (!a.startdatum && !b.startdatum) return 0;
    if (!a.startdatum) return 1;
    if (!b.startdatum) return -1;
    return compareAsc(a.startdatum, b.startdatum);
  });
---

<header class="nav">
  <div class="container nav__inner">
    <a href={url('/')} class="nav__logo">
      <img
        src={url('/logo.svg')}
        alt=""
        aria-hidden="true"
        width="36"
        height="52"
        loading="eager"
        class="nav__logo-mark"
      />
      <span class="nav__logo-name">
        <span class="nav__logo-name-top">Nederlands Centrum voor</span>
        <span class="nav__logo-name-bottom">Curriculumstudies</span>
      </span>
    </a>
    <nav aria-label="Hoofdnavigatie">
      <ul class="nav__links">
        <li class="nav__item"><a href={url('/#agenda')} class="nav__link">Agenda</a></li>
        <li class="nav__item nav__item--has-dropdown">
          <a href={url('/#leergangen')} class="nav__link">Leergangen</a>
          <ul class="nav__dropdown">
            {leergangen.map(({ title, slug }) => (
              <li>
                <a href={url(`/leergang/${slug}/`)} class="nav__dropdown-link">{title}</a>
              </li>
            ))}
          </ul>
        </li>
        <li class="nav__item"><a href={url('/#over-ons')} class="nav__link">Over ons</a></li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-white);
    border-bottom: 2px solid var(--color-bg-tinted-dark);
    height: var(--nav-height);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }

  /* Logo: mark + text side by side */
  .nav__logo {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    text-decoration: none;
    color: var(--color-primary);
  }

  .nav__logo:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
    border-radius: var(--radius-sm);
  }

  .nav__logo-mark {
    height: 60px;
    width: auto;
    flex-shrink: 0;
  }

  .nav__logo-name {
    font-family: 'Open Sans', sans-serif;
    font-size: .9rem;
    line-height: 1;
    letter-spacing: 0.01em;
    color: var(--color-primary);
    display: flex;
    flex-direction: column;
  }

  .nav__logo-name-top {
    font-size: 1em;
    font-weight: 350;
  }

  .nav__logo-name-bottom {
    font-size: 1.38em;
    font-weight: 400;
  }

  /* Nav links */
  .nav__links {
    display: flex;
    align-items: stretch;
    gap: var(--space-md);
    list-style: none;
    height: 100%;
  }

  .nav__item {
    position: relative;
    display: flex;
    align-items: center;
  }

  .nav__link {
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    color: var(--color-primary);
    letter-spacing: 0.02em;
    padding-block: var(--space-xs);
    border-bottom: 2px solid transparent;
    transition: border-color 0.2s;
  }

  .nav__link:hover {
    border-bottom-color: var(--color-primary);
  }

  .nav__link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
    border-radius: var(--radius-sm);
  }

  /* Dropdown */
  .nav__dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    padding-top: var(--space-sm);
    list-style: none;
    min-width: 280px;
    z-index: 200;
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: 0 6px 20px rgba(0,0,0,0.10);
  }

  .nav__dropdown-link {
    display: block;
    padding: 0.6rem 1rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-primary);
    text-decoration: none;
    white-space: normal;
    background: var(--color-white);
    border-left: 3px solid transparent;
    transition: border-color 0.15s, background 0.15s;
  }

  .nav__dropdown-link:hover {
    background: var(--color-bg-tinted-dark);
    border-left-color: var(--color-primary);
  }

  .nav__dropdown-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: -2px;
  }

  /* Show on hover or keyboard focus within */
  .nav__item--has-dropdown:hover > .nav__link,
  .nav__item--has-dropdown:focus-within > .nav__link {
    border-bottom-color: var(--color-primary);
  }

  .nav__item--has-dropdown:hover .nav__dropdown,
  .nav__item--has-dropdown:focus-within .nav__dropdown {
    display: block;
  }

  @media (max-width: 600px) {
    nav { display: none; }
  }
</style>
