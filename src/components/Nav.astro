---
import { url } from '../utils/url';
import { getCollection } from 'astro:content';

const leergangEntries = await getCollection('leergangen');
const leergangen = leergangEntries
  .map(e => e.data)
  .sort((a, b) => a.order - b.order);
---

<header class="nav">
  <div class="container nav__inner">
    <a href={url('/')} class="nav__logo" aria-label="NLCCS — naar de homepage">
      <img
        src={url('/logo.svg')}
        alt="Nederlands Centrum voor Curriculumstudies"
        width="220"
        height="75"
        loading="eager"
      />
    </a>
    <nav aria-label="Hoofdnavigatie">
      <ul class="nav__links">
        <li class="nav__item"><a href={url('/#agenda')} class="nav__link">Agenda</a></li>
        <li class="nav__item nav__item--has-dropdown">
          <a href={url('/#leergangen')} class="nav__link">Leergangen</a>
          <ul class="nav__dropdown">
            <div class="nav__dropdown-box">
              {leergangen.map(({ title, slug }) => (
                <li>
                  <a href={url(`/leergang/${slug}/`)} class="nav__dropdown-link">{title}</a>
                </li>
              ))}
            </div>
          </ul>
        </li>
        <li class="nav__item"><a href={url('/#over-ons')} class="nav__link">Over ons</a></li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-white);
    border-bottom: 2px solid var(--color-bg-warm-dark);
    height: var(--nav-height);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }

  .nav__logo img {
    height: 72px;
    width: auto;
  }

  .nav__links {
    display: flex;
    align-items: stretch;
    gap: var(--space-md);
    list-style: none;
    height: 100%;
  }

  .nav__item {
    position: relative;
    display: flex;
    align-items: center;
  }

  .nav__link {
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    color: var(--color-primary);
    letter-spacing: 0.02em;
    padding-block: 0.25rem;
    border-bottom: 2px solid transparent;
    transition: border-color 0.2s;
  }

  .nav__link:hover {
    border-bottom-color: var(--color-primary);
  }

  /* Dropdown */
  .nav__dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    /* padding-top fills the gap between li bottom and nav bottom edge,
       keeping hover alive the entire way down */
    padding-top: 0.75rem;
    list-style: none;
    min-width: 280px;
    z-index: 200;
  }

  .nav__dropdown-box {
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 0 6px 20px rgba(0,0,0,0.10);
  }

  .nav__dropdown-link {
    display: block;
    padding: 0.6rem 1rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-primary);
    text-decoration: none;
    white-space: normal;
    background: var(--color-white);
    border-left: 3px solid transparent;
    transition: border-color 0.15s, background 0.15s;
  }

  .nav__dropdown-link:hover {
    background: var(--color-bg-warm-dark);
    border-left-color: var(--color-primary);
  }

  /* Show on li:hover so the full area (link + dropdown) keeps hover alive */
  .nav__item--has-dropdown:hover > .nav__link {
    border-bottom-color: var(--color-primary);
  }

  .nav__item--has-dropdown:hover .nav__dropdown {
    display: block;
  }

  @media (max-width: 600px) {
    nav { display: none; }
  }
</style>
